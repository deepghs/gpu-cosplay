#!/usr/bin/env python3
"""Wrapper around the real /usr/bin/nvidia-smi.

Runs the real binary, then post-processes stdout/stderr to substitute the
host GPU's name and physical MIG slice memory with the target GPU's name and
advertised VRAM. Falls through unchanged when env vars aren't set.

Env vars consumed (set by `gpu-cosplay up`):
  GPU_COSPLAY_PRETTY            target GPU display name, e.g. "RTX 3090"
  GPU_COSPLAY_VRAM_GB           target VRAM in GB (float), e.g. "24"
  GPU_COSPLAY_PHYS_VRAM_MIB     physical slice memory in MiB, e.g. "17152"
"""

from __future__ import annotations
import os
import re
import subprocess
import sys

import shutil


# We never rename or replace the real binary. The shim lives at
# /usr/local/bin/nvidia-smi (first on PATH); the real one stays wherever the
# driver package installed it. We find it via shutil.which after dropping our
# own directory from PATH.
def _find_real() -> str:
    here = os.path.realpath(__file__)
    self_dir = os.path.realpath(os.path.dirname(here))
    path = os.environ.get("PATH", os.defpath)
    alt = os.pathsep.join(
        d for d in path.split(os.pathsep) if d and os.path.realpath(d) != self_dir
    )
    real = shutil.which("nvidia-smi", path=alt)
    if not real:
        raise SystemExit("[nvidia-smi shim] could not find the real nvidia-smi on PATH")
    return real


REAL = _find_real()


def _rewrite(text: str, name: str, target_mib: int, phys_mib: int) -> str:
    if not text:
        return text
    # 1. Device name substitutions. nvidia-smi prints things like:
    #    "NVIDIA H200", "NVIDIA H200 MIG 1g.18gb",
    #    "NVIDIA A100-SXM4-80GB", "NVIDIA A100-SXM4-80GB MIG 2g.20gb"
    text = re.sub(
        r"NVIDIA (?:H\d+|A100[-\w]*|A30|A40|A10|H100[-\w]*|GH\d+)(?:\s+MIG\s+\d+g\.\d+gb)?",
        name,
        text,
    )

    # 2. Memory total substitution: replace any occurrence of the physical
    #    MIG slice memory with the target VRAM. Restrict to tokenish
    #    occurrences (not adjacent to other digits) to avoid stomping unrelated
    #    numbers in the report.
    if phys_mib > 0 and target_mib > 0:
        text = re.sub(rf"(?<!\d){phys_mib}(?!\d)", str(target_mib), text)

    # 3. nvidia-smi -L's MIG sub-line ("  MIG 1g.18gb  Device 0: (UUID: ...)")
    #    — strip so the listing looks like a single non-MIG device.
    text = re.sub(r"\n  MIG \d+g\.\d+gb\s+Device\s+\d+:[^\n]*", "", text)

    # 4. "[Insufficient Permissions]" — inside a MIG slice, --query-gpu queries
    #    for memory.total / power.* / etc return this string. Substitute the
    #    target's value when we know what was asked. The query string is in
    #    sys.argv, e.g. "--query-gpu=name,memory.total,power.max_limit".
    text = _patch_query_gpu(text, name, target_mib)
    return text


def _patch_query_gpu(text: str, name: str, target_mib: int) -> str:
    """Rewrite values in --query-gpu --format=csv output to match the target.

    Some fields nvidia-smi returns from inside a MIG slice are "[Insufficient
    Permissions]" (memory.total). Other fields return the host's real value
    (power.max_limit returns the host GPU's TDP, not the slice's). Either way,
    if we know the right answer for the target, we substitute.
    """
    args = sys.argv[1:]
    fields: list[str] = []
    for a in args:
        if a.startswith("--query-gpu="):
            fields = [f.strip() for f in a[len("--query-gpu=") :].split(",")]
            break
    if not fields:
        return text

    tdp_w = float(os.environ.get("GPU_COSPLAY_TDP_W", "0") or 0)
    no_units = any("nounits" in a for a in args)

    def fmt_mib(v_mib: int) -> str:
        return f"{v_mib}" if no_units else f"{v_mib} MiB"

    def fmt_w(v_w: float) -> str:
        return f"{v_w:.2f}" if no_units else f"{v_w:.2f} W"

    replacements: dict[str, str] = {}
    for f in fields:
        f_norm = f.replace(" ", "").lower()
        if f_norm == "memory.total" and target_mib > 0:
            replacements[f] = fmt_mib(target_mib)
        elif f_norm == "memory.free" and target_mib > 0:
            replacements[f] = fmt_mib(target_mib)
        elif f_norm == "memory.used":
            replacements[f] = fmt_mib(0)
        elif f_norm in {"power.max_limit", "power.default_limit"} and tdp_w:
            replacements[f] = fmt_w(tdp_w)
        elif f_norm == "name":
            replacements[f] = name

    if not replacements:
        return text

    out_lines = text.splitlines()
    new_lines = []
    header_seen = False
    for line in out_lines:
        # Header line (when not --format=csv,noheader): pass through.
        if not header_seen and "," in line and not any(c.isdigit() for c in line.split(",")[0]):
            new_lines.append(line)
            header_seen = True
            continue
        cols = [c.strip() for c in line.split(",")]
        if len(cols) != len(fields):
            new_lines.append(line)
            continue
        for i, f in enumerate(fields):
            if f in replacements:
                # Always overwrite — host's value (e.g. 700W TDP) is wrong for
                # the target (e.g. 350W for RTX 3090), and so is "[Insufficient
                # Permissions]" for MIG-restricted fields.
                cols[i] = replacements[f]
        new_lines.append(", ".join(cols))
    return "\n".join(new_lines) + ("\n" if text.endswith("\n") else "")


def main() -> int:
    p = subprocess.run([REAL] + sys.argv[1:], capture_output=True, text=True)

    name = (os.environ.get("GPU_COSPLAY_PRETTY") or "").strip()
    vram_gb = os.environ.get("GPU_COSPLAY_VRAM_GB") or ""
    phys_mib_str = os.environ.get("GPU_COSPLAY_PHYS_VRAM_MIB") or ""

    target_mib = 0
    phys_mib = 0
    if vram_gb and phys_mib_str:
        try:
            target_mib = int(round(float(vram_gb) * 1024))
            phys_mib = int(phys_mib_str)
        except (ValueError, TypeError):
            pass

    out = _rewrite(p.stdout, name, target_mib, phys_mib) if name else p.stdout
    err = _rewrite(p.stderr, name, target_mib, phys_mib) if name else p.stderr

    sys.stdout.write(out)
    sys.stderr.write(err)
    return p.returncode


if __name__ == "__main__":
    sys.exit(main())
